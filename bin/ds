source "${D_DIR}/lib/defaults.sh"
source "${D_DIR}/lib/config.sh"

source "${D_DIR}/lib/header.sh"

source "${D_DIR}/lib/plugins.sh"

source "${D_DIR}/lib/footer.sh"
